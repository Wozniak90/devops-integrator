{
  "name": "devops-integrator",
  "version": "1.0.0",
  "description": "Standalone Azure DevOps work item viewer with setup wizard",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev":   "node --watch server.js",
    "mcp":   "node mcp-server.mjs",
    "type-check": "node scripts/type-check.mjs",
    "lint": "node scripts/lint.mjs",
    "lint:fix": "node scripts/lint.mjs --fix",
    "format:check": "node scripts/format.mjs --check",
    "format": "node scripts/format.mjs --write",
    "test": "node --test mcp-test.mjs",
    "build": "npm pack --dry-run"
  },
  "dependencies": {
    "express": "^5.0.1",
    "@modelcontextprotocol/sdk": "^1.10.2",
    "zod": "^3.23.8"
  }
}
